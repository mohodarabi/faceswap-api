PORT=8080
ENV=dev
NOVITA_API_KEY=your-novita-api-key
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-secret
MAX_BODY_SIZE=20971520

# Either DATABASE_URL or the POSTGRES_* variables can be used.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/faceswap
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=faceswap
POSTGRES_SSL=false
